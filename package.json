{
  "name": "antdv-next-admin",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vue-tsc -b && vp build",
    "preview": "vp preview",
    "check": "vp check --fix",
    "gen:perType": "cross-env NODE_ENV=development esno scripts/gen-per-type.ts",
    "db:generate:dev": "cross-env NODE_ENV=development drizzle-kit generate",
    "db:migrate:dev": "cross-env NODE_ENV=development drizzle-kit migrate",
    "db:pull:dev": "cross-env NODE_ENV=development drizzle-kit pull",
    "db:push:dev": "cross-env NODE_ENV=development drizzle-kit push",
    "db:up:dev": "cross-env NODE_ENV=development drizzle-kit up",
    "db:generate:prod": "cross-env NODE_ENV=production drizzle-kit generate",
    "db:migrate:prod": "cross-env NODE_ENV=production drizzle-kit migrate",
    "db:pull:prod": "cross-env NODE_ENV=production drizzle-kit pull",
    "db:push:prod": "cross-env NODE_ENV=production drizzle-kit push",
    "db:up:prod": "cross-env NODE_ENV=production drizzle-kit up",
    "start": "node ./.output/server/index.mjs",
    "prepare": "vp config"
  },
  "dependencies": {
    "@alova/mock": "^2.0.20",
    "@antdv-next/icons": "^1.0.6",
    "@antdv-next/tailwind": "^1.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vueuse/core": "^14.2.1",
    "alova": "^3.5.1",
    "antdv-next": "^1.1.9",
    "es-toolkit": "^1.45.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "trickling": "^1.14.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.1",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antdv-next/auto-import-resolver": "^1.0.7",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@vitejs/devtools": "^0.1.13",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.20",
    "drizzle-kit": "^1.0.0-beta.9-e89174b",
    "drizzle-orm": "^1.0.0-beta.20",
    "esno": "^4.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "nitro": "^3.0.260311-beta",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.59.0",
    "pg": "^8.20.0",
    "typescript": "^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "uuid": "^13.0.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.16",
    "vite-plugin-dayjs": "^1.0.1",
    "vite-plugin-inspect": "^11.3.3",
    "vite-plus": "^0.1.16",
    "vue-tsc": "^3.2.6"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.16",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.16"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.16",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.16"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.16",
      "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.16"
    }
  }
}
