{
  "name": "antdv-next-admin",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "db:generate:dev": "cross-env NODE_ENV=development drizzle-kit generate",
    "db:migrate:dev": "cross-env NODE_ENV=development drizzle-kit migrate",
    "db:pull:dev": "cross-env NODE_ENV=development drizzle-kit pull",
    "db:push:dev": "cross-env NODE_ENV=development drizzle-kit push",
    "db:up:dev": "cross-env NODE_ENV=development drizzle-kit up",
    "db:generate:prod": "cross-env NODE_ENV=production drizzle-kit generate",
    "db:migrate:prod": "cross-env NODE_ENV=production drizzle-kit migrate",
    "db:pull:prod": "cross-env NODE_ENV=production drizzle-kit pull",
    "db:push:prod": "cross-env NODE_ENV=production drizzle-kit push",
    "db:up:prod": "cross-env NODE_ENV=production drizzle-kit up",
    "start": "node ./.output/server/index.mjs",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@antdv-next/icons": "^1.0.5",
    "@antdv-next/tailwind": "^1.0.2",
    "@tailwindcss/vite": "^4.2.1",
    "@vueuse/core": "^14.2.1",
    "antdv-next": "^1.1.4",
    "axios": "^1.13.6",
    "es-toolkit": "^1.45.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.1",
    "trickling": "^1.14.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@antdv-next/auto-import-resolver": "^1.0.7",
    "@antfu/eslint-config": "^7.7.2",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.18.0",
    "@vitejs/devtools": "0.0.0-alpha.34",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.20",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "jiti": "^2.6.1",
    "nitro": "^3.0.260311-beta",
    "pg": "^8.20.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "uuid": "^13.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dayjs": "^1.0.1",
    "vite-plugin-inspect": "^11.3.3",
    "vue-tsc": "^3.2.5"
  }
}
