{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "rootDir": ".",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"],
      "@apps/admin/*": ["./apps/admin/src/*"],
      "#db/*": ["./server/db/schema/*"]
    },

    "types": ["vite-plus/client", "antdv-next/global", "unplugin-icons/types/vue"],
    /* Linting */
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "types/**/*.d.ts",
    "server/**/*.ts",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "apps/**/*.vue",
    "mock/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__tests__/*.test.ts",
    "src/**/__tests__/*.test.tsx",
    "mock/**/*.spec.ts",
    "mock/**/*.test.ts",
    "mock/**/__tests__/**/*.ts"
  ],
  "vueCompilerOptions": {
    "plugins": ["vue-router/volar/sfc-route-blocks", "vue-router/volar/sfc-typed-router"]
  }
}
