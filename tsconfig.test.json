{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "types": ["vite-plus/client", "node"],
    "noEmit": true
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "apps/**/*.spec.ts",
    "apps/**/*.spec.tsx",
    "apps/**/*.test.ts",
    "apps/**/*.test.tsx",
    "apps/**/__tests__/**/*.ts",
    "apps/**/__tests__/**/*.tsx",
    "mock/**/*.spec.ts",
    "mock/**/*.test.ts",
    "types/**/*.d.ts"
  ],
  "exclude": []
}
